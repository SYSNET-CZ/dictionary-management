# ---------------------------------------------------------------------------
# .env.template — šablona pro produkční konfiguraci Docker Compose
# Zkopírujte do .env a doplňte skutečné hodnoty:
#   cp .env.template .env
# ---------------------------------------------------------------------------

# Verze Docker image — musí odpovídat tagu v registru
# Generuje build.sh ze souboru VERSION v kořeni repozitáře
DICT_VERSION=2.0.2

# Zobrazovaný název aplikace
DICT_NAME=SYSNET Managed Dictionaries

# Port, na kterém bude služba dostupná na hostu
DICT_PORT=8080

# MongoDB připojení
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USERNAME=root
MONGO_PASSWORD=DOPLNIT_SILNE_HESLO
